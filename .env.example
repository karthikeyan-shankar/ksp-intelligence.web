# ═══════════════════════════════════════════════════════════════
#  KSP Crime Database — Environment Configuration
# ═══════════════════════════════════════════════════════════════
#  Copy this file to .env and fill in your values.
#  DO NOT commit .env to version control.
# ═══════════════════════════════════════════════════════════════

# Server port
PORT=3000

# AI Model Configuration (for the AI team to fill in)
AI_MODEL_API_KEY=your_api_key_here
AI_MODEL_ENDPOINT=http://localhost:5000/predict

# Session secret (change in production)
SESSION_SECRET=ksp-platform-secret-key

# Database path (optional — defaults to ./ksp_crime.db)
# DB_PATH=./ksp_crime.db
